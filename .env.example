# Copy to .env.local for local dev, and set the same vars in Vercel Project Settings > Environment Variables.

# GitHub fine-grained or classic Personal Access Token.
# Needs scopes: "Contents: read/write" + "Actions" (classic: repo).
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# The owner (your username or org) and repo name that holds the build-apk workflow.
GITHUB_OWNER=your-github-username
GITHUB_REPO=url-to-apk
